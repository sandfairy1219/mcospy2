{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/tauri/tauri.conf.json",
  "productName": "mcospy",
  "version": "1.0.6",
  "identifier": "com.sandfairy1219.mcospy",
  "build": {
    "frontendDist": "../public",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mcospy v1.0.6",
        "url": "main.html",
        "width": 300,
        "height": 400,
        "resizable": true,
        "maximizable": false,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/bridge"
    ],
    "resources": [
      "frida_binding.node",
      "agent.js"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "publisher": "sandfairy1219"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/sandfairy1219/mcospy2/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3RjQ2OTMwMEQ5MzI3MzEKUldReEo1TU5NR24wTitXODRPbDlHZFo4YXVYMVZxQmN1c1hrVWpGbGsvbUVyak5lcHk4TVdqSUcK"
    }
  }
}
