{
    "extends": "./tsconfig.json",
    "compilerOptions": {
      "outDir": "public/scripts", // scripts 폴더 내 파일의 출력 디렉토리
      "sourceMap": false,
      "typeRoots": ["node_modules/@types", "src/types.d.ts"],
    },
    "include": ["src/scripts/**/*"], // scripts 내 모든 .ts 파일 포함
    "exclude": []
  }
  